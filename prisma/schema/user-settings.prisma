enum Theme {
  SYSTEM
  LIGHT
  DARK
}

model UserSettings {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id])
  theme           Theme  @default(SYSTEM)
  notifications   Boolean @default(true)
  subscriptionTier String @default("free")
}